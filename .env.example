# KentTalep — Kök ortam değişkenleri (Docker altyapısı için)
# Bu dosya örnektir; `cp .env.example .env` ile kopyalayın.
# Buradaki değerler yerel geliştirme içindir, gerçek secret DEĞİLDİR.

# PostgreSQL + PostGIS
POSTGRES_USER=kenttalep
POSTGRES_PASSWORD=kenttalep
POSTGRES_DB=kenttalep

# MinIO (S3 uyumlu obje deposu — Faz 0'da kullanılmaz, altyapı hazırlığı)
MINIO_ROOT_USER=kenttalep
MINIO_ROOT_PASSWORD=kenttalep123
